# Cloud.ru Foundation Models (OpenAI-compatible) API key.
# Used server-side only by /api/chat for the AI assistant.
# Default model: openai/gpt-oss-120b (override with CLOUDRU_FM_MODEL).
# Copy this file to .env.local and paste your key. NEVER commit real keys.
CLOUDRU_FM_API_KEY=

# Optional overrides (defaults shown):
# CLOUDRU_FM_BASE_URL=https://foundation-models.api.cloud.ru/v1
# CLOUDRU_FM_MODEL=openai/gpt-oss-120b

# IndexNow (SEO) — push new/updated URLs to Yandex & Bing after deploy.
# Run: npm run seo:indexnow  (see scripts/indexnow.ts)
# The key file must be live at https://<host>/<INDEXNOW_KEY>.txt (committed in public/).
# SITE_URL=https://cloudfinops.ru
# INDEXNOW_KEY=d340d6f02d0606daf4eaff3243aa7dd0
# INDEXNOW_ONLY=/news/<id>   # optional: ping only specific changed URLs
