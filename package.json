{
  "name": "cloudfinops-site",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "predev": "npm run data:build",
    "prebuild": "npm run data:build",
    "data:build": "tsx scripts/build-catalog.ts",
    "data:embeddings": "tsx scripts/build-embeddings.ts",
    "eval:retrieval": "tsx scripts/eval/retrieval-run.ts",
    "eval:smoke": "tsx scripts/eval/smoke.ts --suite",
    "eval:chat": "tsx scripts/eval/smoke.ts",
    "eval:bench": "tsx scripts/eval/benchmark.ts",
    "eval:run": "tsx scripts/eval/run.ts",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "seo:indexnow": "tsx scripts/indexnow.ts",
    "lint": "next lint",
    "theme:brand": "tsx scripts/generate-brand-theme.ts",
    "test": "tsx --test src/lib/calculator/**/*.test.ts src/lib/chat/**/*.test.ts src/lib/catalog/**/*.test.ts"
  },
  "dependencies": {
    "@gravity-ui/aikit": "^2.11.0",
    "@gravity-ui/icons": "^2.20.0",
    "@gravity-ui/illustrations": "^2.1.1",
    "@gravity-ui/uikit": "^7.46.0",
    "@react-three/fiber": "^9.6.1",
    "@shadergradient/react": "^2.4.20",
    "camera-controls": "^3.1.2",
    "js-yaml": "^5.2.1",
    "next": "^15.5.20",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "three-stdlib": "^2.36.1"
  },
  "devDependencies": {
    "@gravity-ui/uikit-themer": "^1.8.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  }
}
